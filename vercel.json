{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "crons": [
    { "path": "/api/cron/refresh-cars", "schedule": "0 0 * * *" }
  ],
  "functions": {
    "api/cars.js": {
      "includeFiles": "api/fallback-cars.json"
    },
    "api/cron/refresh-cars.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
